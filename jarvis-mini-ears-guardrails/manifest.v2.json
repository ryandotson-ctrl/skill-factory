    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:jarvis-mini-ears-guardrails:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "jarvis_ears_guardrails_requested",
      "type": "pulse.event",
      "pattern": "jarvis:ears_guardrails_requested",
      "route_mode": "owned",
      "route_priority": 90
