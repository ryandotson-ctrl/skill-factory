{
  "schema_version": "2.0.0",
  "display_name": "runtime-context-launcher",
  "description": "Detects PFEMacOSApp runtime context, launches the backend, and verifies chat-ready bundle-scoped ownership before trusting startup",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:runtime-context-launcher:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "runtime_context_launch_requested",
      "type": "pulse.event",
      "pattern": "runtime:context_launch_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:runtime-context-launcher"
    }
  ]
}
