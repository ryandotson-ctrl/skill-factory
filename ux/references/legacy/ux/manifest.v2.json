{
  "schema_version": "2.0.0",
  "display_name": "ux",
  "description": "Designs and audits product experiences, IA, interaction specs, accessibility, motion, visual systems, model UX, and handoff quality.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:ux:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "semantic_request",
      "type": "pulse.event",
      "pattern": "ux:brief_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:ux",
      "event_producer_role": "core_status"
    },
    {
      "id": "ready",
      "type": "pulse.event",
      "event_type": "ux:spec_ready",
      "event_producer_role": "core_ready"
    }
  ],
  "awareness": [
    "engineering",
    "automation",
    "artifacts",
    "research",
    "platforms"
  ]
}
