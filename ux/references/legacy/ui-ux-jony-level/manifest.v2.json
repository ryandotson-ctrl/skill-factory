{
  "schema_version": "2.0.0",
  "display_name": "UI UX Ive Level",
  "description": "Modular UX spec factory for strategy, audits, design systems, and platform-aware handoff.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "system_stability_trigger",
      "type": "pulse.event",
      "pattern": "stability_gate_check"
    },
    {
      "id": "ux_brief_requested",
      "type": "pulse.event",
      "pattern": "ux:brief_requested",
      "route_mode": "owned",
      "route_priority": 80
    },
    {
      "id": "ux_audit_requested",
      "type": "pulse.event",
      "pattern": "ux:audit_requested",
      "route_mode": "owned",
      "route_priority": 85
    },
    {
      "id": "ux_system_requested",
      "type": "pulse.event",
      "pattern": "ux:system_requested",
      "route_mode": "owned",
      "route_priority": 82
    },
    {
      "id": "ux_handoff_requested",
      "type": "pulse.event",
      "pattern": "ux:handoff_requested",
      "route_mode": "owned",
      "route_priority": 84
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "ui_ux_jony_level_activity"
    },
    {
      "id": "ux_strategy_ready",
      "type": "pulse.event",
      "event_type": "ui_ux_strategy_ready"
    },
    {
      "id": "ux_review_ready",
      "type": "pulse.event",
      "event_type": "ui_ux_review_ready"
    },
    {
      "id": "ux_design_system_ready",
      "type": "pulse.event",
      "event_type": "ui_ux_design_system_ready"
    },
    {
      "id": "ux_handoff_ready",
      "type": "pulse.event",
      "event_type": "ui_ux_handoff_ready"
    }
  ]
}
