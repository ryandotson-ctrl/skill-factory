{
  "schema_version": "2.0.0",
  "display_name": "agentic-design-contract-architect",
  "description": "Portable design-contract builder for agentic engineering. Use when a task needs an explicit approach, interfaces, invariants, failure modes, and acceptance checks before implementation, especially for medium-risk or high-risk features, refactors, integrations, and critical paths.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:agentic-design-contract-architect:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "engineering_design_contract_requested",
      "type": "pulse.event",
      "pattern": "engineering:design_contract_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:agentic-design-contract-architect"
    }
  ]
}
