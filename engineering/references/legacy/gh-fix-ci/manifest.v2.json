{
  "schema_version": "2.0.0",
  "display_name": "GH Fix CI",
  "description": "Inspect failing GitHub Actions PR checks and produce an evidence-backed fix plan before implementation.",
  "dispatch": {
    "mode": "manual",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:gh-fix-ci:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "ci_fix_requested",
      "type": "pulse.event",
      "pattern": "github:ci_fix_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "ci_fix_plan_ready",
      "type": "pulse.event",
      "event_type": "github:ci_fix_plan_ready"
    },
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:gh-fix-ci"
    }
  ]
}
