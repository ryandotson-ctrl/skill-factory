{
    "schema_version": "2.0.0",
    "display_name": "Git Sentinel Release Manager",
    "dispatch": {
        "mode": "automatic",
        "cooldown": 300
    },
    "inputs": [
        {
            "id": "system_stability_trigger",
            "type": "pulse.event",
            "pattern": "stability_gate_check"
        },
        {
            "id": "hygiene_check_request",
            "type": "pulse.event",
            "pattern": "git_hygiene_check_requested"
        }
    ],
    "outputs": [
        {
            "id": "hygiene_report",
            "type": "pulse.event",
            "event_type": "hygiene_report_emitted"
        },
        {
            "id": "release_blocker",
            "type": "pulse.event",
            "event_type": "release_blocked"
        }
    ]
}