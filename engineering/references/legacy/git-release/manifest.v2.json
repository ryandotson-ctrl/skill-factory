{
  "schema_version": "2.0.0",
  "display_name": "git-release",
  "description": "Lean core git, release, repo, CI, issue, and collaboration skill.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:git-release:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "release_requested",
      "type": "pulse.event",
      "pattern": "git:release_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:git-release",
      "event_producer_role": "core_status"
    },
    {
      "id": "release_receipt_ready",
      "type": "pulse.event",
      "event_type": "git:release_receipt_ready",
      "event_producer_role": "release_receipt"
    }
  ],
  "awareness": [
    "engineering",
    "skill-governor",
    "security"
  ]
}
