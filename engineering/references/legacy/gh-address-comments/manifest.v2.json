{
  "schema_version": "2.0.0",
  "display_name": "GH Address Comments",
  "description": "Inspect and address actionable GitHub PR review comments with gh CLI after user confirmation.",
  "dispatch": {
    "mode": "manual",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:gh-address-comments:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "review_comments_requested",
      "type": "pulse.event",
      "pattern": "github:review_comments_address_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "review_comments_ready",
      "type": "pulse.event",
      "event_type": "github:review_comments_address_ready"
    },
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:gh-address-comments"
    }
  ]
}
