{
  "schema_version": "2.0.0",
  "display_name": "engineering",
  "description": "Routes software work through reality inspection, risk classification, implementation, QA, code audit, git hygiene, CI, and release closure.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:engineering:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "semantic_request",
      "type": "pulse.event",
      "pattern": "engineering:execution_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:engineering",
      "event_producer_role": "core_status"
    },
    {
      "id": "ready",
      "type": "pulse.event",
      "event_type": "engineering:delivery_ready",
      "event_producer_role": "core_ready"
    }
  ],
  "awareness": [
    "reliability",
    "security",
    "knowledge-data",
    "automation",
    "ux",
    "platforms"
  ]
}
