{
  "schema_version": "2.0.0",
  "display_name": "ChatGPT Apps",
  "description": "Build, scaffold, refactor, and troubleshoot ChatGPT Apps SDK applications with a docs-first workflow.",
  "dispatch": {
    "mode": "manual",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:chatgpt-apps:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "chatgpt_apps_requested",
      "type": "pulse.event",
      "pattern": "openai:chatgpt_apps_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "chatgpt_apps_ready",
      "type": "pulse.event",
      "event_type": "chatgpt_apps_ready"
    },
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:chatgpt-apps"
    }
  ]
}
