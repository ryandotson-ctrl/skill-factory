{
  "schema_version": "2.0.0",
  "display_name": "Image Gen",
  "description": "Generate or edit images using the bundled OpenAI Image API CLI workflow.",
  "dispatch": {
    "mode": "manual",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:imagegen:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "image_generate_requested",
      "type": "pulse.event",
      "pattern": "image:generate_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "image_generated",
      "type": "pulse.event",
      "event_type": "image:generated"
    },
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:imagegen",
      "event_producer_role": "primary_skill"
    }
  ]
}
