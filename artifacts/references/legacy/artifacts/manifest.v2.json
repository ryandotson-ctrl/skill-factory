{
  "schema_version": "2.0.0",
  "display_name": "artifacts",
  "description": "Creates, inspects, converts, validates, and packages PDFs, slides, spreadsheets, images, logos, and ChatGPT Apps.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:artifacts:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "semantic_request",
      "type": "pulse.event",
      "pattern": "artifacts:create_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:artifacts",
      "event_producer_role": "core_status"
    },
    {
      "id": "ready",
      "type": "pulse.event",
      "event_type": "artifacts:package_ready",
      "event_producer_role": "core_ready"
    }
  ],
  "awareness": [
    "ux",
    "automation",
    "research",
    "security",
    "engineering"
  ]
}
