{
  "schema_version": "2.0.0",
  "display_name": "rag-data",
  "description": "Lean core RAG and data-contract skill for retrieval, schemas, telemetry, evals, compatibility, and checksums.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:rag-data:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "data_contract_check_requested",
      "type": "pulse.event",
      "pattern": "data:contract_check_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:rag-data",
      "event_producer_role": "core_status"
    },
    {
      "id": "contract_report_ready",
      "type": "pulse.event",
      "event_type": "data:contract_report_ready",
      "event_producer_role": "contract_report"
    }
  ],
  "awareness": [
    "ml",
    "reliability",
    "pfe-profile"
  ]
}
