{
  "schema_version": "2.0.0",
  "display_name": "Experiment Ledger Packager",
  "dispatch": {
    "mode": "hybrid",
    "cooldown": 600
  },
  "inputs": [
    {
      "id": "experiment_package_requested",
      "type": "pulse.event",
      "pattern": "experiment:package_requested",
      "route_mode": "owned",
      "route_priority": 75
    },
    {
      "id": "eval_summary_emitted",
      "type": "pulse.event",
      "pattern": "eval:summary_emitted"
    },
    {
      "id": "run_finished",
      "type": "pulse.event",
      "pattern": "run:finished"
    }
  ],
  "outputs": [
    {
      "id": "ledger_packaged",
      "type": "pulse.event",
      "event_type": "experiment:ledger_packaged"
    },
    {
      "id": "replay_manifest_emitted",
      "type": "pulse.event",
      "event_type": "experiment:replay_manifest_emitted"
    }
  ]
}
