{
  "schema_version": "2.0.0",
  "display_name": "Target Compatibility Gate",
  "dispatch": {
    "mode": "hybrid",
    "cooldown": 600
  },
  "inputs": [
    {
      "id": "compatibility_check_requested",
      "type": "pulse.event",
      "pattern": "compatibility:check_requested",
      "route_mode": "owned",
      "route_priority": 80
    },
    {
      "id": "artifact_ready_for_target_check",
      "type": "pulse.event",
      "pattern": "artifact:ready_for_target_check"
    }
  ],
  "outputs": [
    {
      "id": "gate_passed",
      "type": "pulse.event",
      "event_type": "compatibility:gate_passed"
    },
    {
      "id": "gate_blocked",
      "type": "pulse.event",
      "event_type": "compatibility:gate_blocked"
    },
    {
      "id": "transform_plan_emitted",
      "type": "pulse.event",
      "event_type": "compatibility:transform_plan_emitted"
    }
  ]
}
