{
  "schema_version": "2.0.0",
  "display_name": "Harmonious Sync Orchestrator",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 180
  },
  "inputs": [
    {
      "id": "stability_gate_trigger",
      "type": "pulse.event",
      "pattern": "stability_gate_check"
    },
    {
      "id": "git_push_requested",
      "type": "pulse.event",
      "pattern": "git.push.requested"
    },
    {
      "id": "partner_sync_requested",
      "type": "pulse.event",
      "pattern": "partner.sync.requested"
    },
    {
      "id": "release_preflight_completed",
      "type": "pulse.event",
      "pattern": "release.preflight.completed"
    },
    {
      "id": "bundle_integrity_failed",
      "type": "pulse.event",
      "pattern": "bundle.integrity.failed"
    },
    {
      "id": "skill_mirror_changed",
      "type": "pulse.event",
      "pattern": "skill.mirror.changed"
    },
    {
      "id": "portability_violation_detected",
      "type": "pulse.event",
      "pattern": "portability.violation.detected"
    }
  ],
  "outputs": [
    {
      "id": "sync_audit_completed",
      "type": "pulse.event",
      "event_type": "sync.audit.completed"
    },
    {
      "id": "sync_blocked",
      "type": "pulse.event",
      "event_type": "sync.blocked"
    },
    {
      "id": "sync_partner_ready",
      "type": "pulse.event",
      "event_type": "sync.partner_ready"
    },
    {
      "id": "sync_bundle_gap_detected",
      "type": "pulse.event",
      "event_type": "sync.bundle_gap_detected"
    },
    {
      "id": "sync_local_only_artifacts_detected",
      "type": "pulse.event",
      "event_type": "sync.local_only_artifacts_detected"
    }
  ]
}
