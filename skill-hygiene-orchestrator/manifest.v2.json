{
  "schema_version": "2.0.0",
  "display_name": "skill-hygiene-orchestrator",
  "description": "Audits and de-duplicates skills across Codex (~/.codex/skills), Antigravity",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:skill-hygiene-orchestrator:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "skills_hygiene_requested",
      "type": "pulse.event",
      "pattern": "skills:hygiene_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:skill-hygiene-orchestrator"
    }
  ]
}
