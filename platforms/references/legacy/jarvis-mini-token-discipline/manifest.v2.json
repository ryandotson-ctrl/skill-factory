{
  "schema_version": "2.0.0",
  "display_name": "jarvis-mini-token-discipline",
  "description": "Enforce Jarvis Mini token and budget discipline on Pi. Use when token",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:jarvis-mini-token-discipline:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "jarvis_token_discipline_requested",
      "type": "pulse.event",
      "pattern": "jarvis:token_discipline_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:jarvis-mini-token-discipline"
    }
  ]
}
