{
  "schema_version": "2.0.0",
  "display_name": "apple",
  "description": "Lean core Apple platform skill for project adoption, Xcode harnessing, verification, and release.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:apple:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "apple_project_requested",
      "type": "pulse.event",
      "pattern": "apple:project_requested",
      "route_mode": "owned",
      "route_priority": 92
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:apple",
      "event_producer_role": "core_status"
    },
    {
      "id": "receipt_ready",
      "type": "pulse.event",
      "event_type": "apple:receipt_ready",
      "event_producer_role": "apple_receipt"
    }
  ],
  "awareness": [
    "engineering",
    "git-release",
    "pfe-profile"
  ]
}
