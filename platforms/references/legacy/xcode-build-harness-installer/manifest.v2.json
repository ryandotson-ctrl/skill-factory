{
  "schema_version": "2.0.0",
  "display_name": "Xcode Build Harness",
  "description": "Install or upgrade an isolated Apple CLI build harness with reproducible diagnose, build, test, run, and agent-verify targets.",
  "dispatch": {
    "mode": "hybrid",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "apple_build_harness_install_requested",
      "type": "pulse.event",
      "pattern": "apple:build_harness_install_requested"
    }
  ],
  "outputs": [
    {
      "id": "apple_build_harness_receipt",
      "type": "pulse.event",
      "event_type": "apple:build_harness_receipt"
    },
    {
      "id": "xcode_build_harness_installer_activity",
      "type": "pulse.event",
      "event_type": "xcode_build_harness_installer_activity"
    }
  ]
}
