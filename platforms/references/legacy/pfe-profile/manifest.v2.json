{
  "schema_version": "2.0.0",
  "display_name": "pfe-profile",
  "description": "Lean profile skill for Project Free Energy-specific runtime, RAG, schema, model, web, and uptime wisdom.",
  "dispatch": {
    "mode": "manual",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:pfe-profile:requested",
      "route_mode": "owned",
      "route_priority": 85
    },
    {
      "id": "pfe_profile_requested",
      "type": "pulse.event",
      "pattern": "profile:pfe_requested",
      "route_mode": "owned",
      "route_priority": 85
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:pfe-profile",
      "event_producer_role": "profile_status"
    },
    {
      "id": "pfe_context_ready",
      "type": "pulse.event",
      "event_type": "profile:pfe_context_ready",
      "event_producer_role": "profile_context"
    }
  ],
  "awareness": [
    "apple",
    "rag-data",
    "reliability",
    "ml"
  ]
}
