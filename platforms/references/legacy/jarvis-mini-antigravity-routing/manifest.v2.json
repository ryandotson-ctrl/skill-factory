{
  "schema_version": "2.0.0",
  "display_name": "jarvis-mini-antigravity-routing",
  "description": "Manage Jarvis Mini Google Antigravity authentication and model routing",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:jarvis-mini-antigravity-routing:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "jarvis_antigravity_routing_requested",
      "type": "pulse.event",
      "pattern": "jarvis:antigravity_routing_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:jarvis-mini-antigravity-routing"
    }
  ]
}
