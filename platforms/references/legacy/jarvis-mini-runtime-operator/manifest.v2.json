{
  "schema_version": "2.0.0",
  "display_name": "jarvis-mini-runtime-operator",
  "description": "Operate Jarvis Mini runtime on the Raspberry Pi OpenClaw stack. Use when",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:jarvis-mini-runtime-operator:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "jarvis_runtime_operation_requested",
      "type": "pulse.event",
      "pattern": "jarvis:runtime_operation_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:jarvis-mini-runtime-operator"
    }
  ]
}
