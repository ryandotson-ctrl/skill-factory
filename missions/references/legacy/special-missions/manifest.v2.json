{
  "schema_version": "2.0.0",
  "display_name": "special-missions",
  "description": "Lean gated mission skill for bounded high-autonomy workflows.",
  "dispatch": {
    "mode": "manual",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:special-missions:requested",
      "route_mode": "owned",
      "route_priority": 85
    },
    {
      "id": "autonomous_mission_requested",
      "type": "pulse.event",
      "pattern": "mission:autonomous_requested",
      "route_mode": "owned",
      "route_priority": 85
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:special-missions",
      "event_producer_role": "mission_status"
    },
    {
      "id": "receipt_ready",
      "type": "pulse.event",
      "event_type": "mission:receipt_ready",
      "event_producer_role": "mission_receipt"
    }
  ],
  "awareness": [
    "automation",
    "security",
    "git-release"
  ]
}
