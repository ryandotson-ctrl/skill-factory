{
  "schema_version": "2.0.0",
  "display_name": "missions",
  "description": "Runs bounded, permission-aware autonomous mission packs that require explicit constraints, trackers, evidence, and stop conditions.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:missions:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "semantic_request",
      "type": "pulse.event",
      "pattern": "missions:autonomous_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:missions",
      "event_producer_role": "core_status"
    },
    {
      "id": "ready",
      "type": "pulse.event",
      "event_type": "missions:mission_ready",
      "event_producer_role": "core_ready"
    }
  ],
  "awareness": [
    "automation",
    "security",
    "engineering",
    "watcher",
    "research"
  ]
}
