{
  "schema_version": "2.0.0",
  "display_name": "playwright",
  "description": "Use when the task requires automating a real browser from the terminal",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:playwright:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "browser_automation_requested",
      "type": "pulse.event",
      "pattern": "browser:automation_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:playwright"
    }
  ]
}
