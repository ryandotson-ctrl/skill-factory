{
  "schema_version": "2.0.0",
  "display_name": "research",
  "description": "Produces current, source-grounded research, official-doc interpretation, technology freshness checks, SOTA scans, and decision intelligence.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:research:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "semantic_request",
      "type": "pulse.event",
      "pattern": "research:brief_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:research",
      "event_producer_role": "core_status"
    },
    {
      "id": "ready",
      "type": "pulse.event",
      "event_type": "research:intelligence_ready",
      "event_producer_role": "core_ready"
    }
  ],
  "awareness": [
    "engineering",
    "knowledge-data",
    "ml",
    "artifacts",
    "platforms"
  ]
}
