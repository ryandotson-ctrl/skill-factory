{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hallucination_audit.schema.json",
  "title": "Hallucination Audit Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_summary",
    "hallucination_class",
    "severity",
    "verdict",
    "confidence",
    "trigger_evidence",
    "tool_evidence",
    "search_evidence",
    "context_evidence",
    "truthfulness_guard_status",
    "root_cause",
    "recommended_owner_skills",
    "recommended_code_changes",
    "recommended_tests",
    "portability_notes"
  ],
  "properties": {
    "request_summary": {
      "type": "string"
    },
    "hallucination_class": {
      "type": "string",
      "enum": [
        "action_hallucination",
        "evidence_hallucination",
        "context_drop_hallucination",
        "confidence_miscalibration",
        "truth_guard_blocked_false_success",
        "deterministic_executor_gap",
        "no_finding"
      ]
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "verdict": {
      "type": "string",
      "enum": ["no_finding", "finding", "guard_success", "gap_detected", "needs_review"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "trigger_evidence": {
      "type": "array",
      "items": {"type": "string"}
    },
    "tool_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_calls", "tool_results", "verification_present"],
      "properties": {
        "tool_calls": {"type": "integer", "minimum": 0},
        "tool_results": {"type": "integer", "minimum": 0},
        "verification_present": {"type": "boolean"},
        "notes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "search_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["distinct_domains", "official_source_present", "finance_priority_present", "evidence_sufficiency"],
      "properties": {
        "distinct_domains": {"type": "integer", "minimum": 0},
        "official_source_present": {"type": "boolean"},
        "finance_priority_present": {"type": "boolean"},
        "evidence_sufficiency": {"type": "string", "enum": ["sufficient", "limited", "unknown"]},
        "notes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "context_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["short_followup", "continuity_preserved"],
      "properties": {
        "short_followup": {"type": "boolean"},
        "continuity_preserved": {"type": "boolean"},
        "notes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "truthfulness_guard_status": {
      "type": "string",
      "enum": ["not_triggered", "blocked_false_success", "unknown"]
    },
    "root_cause": {
      "type": "string"
    },
    "recommended_owner_skills": {
      "type": "array",
      "items": {"type": "string"}
    },
    "recommended_code_changes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "recommended_tests": {
      "type": "array",
      "items": {"type": "string"}
    },
    "portability_notes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "pulse_events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_type", "payload"],
        "properties": {
          "event_type": {"type": "string"},
          "payload": {"type": "object"}
        }
      }
    }
  }
}
