{
  "schema_version": "2.0.0",
  "display_name": "jarvis-mini-openclaw-release-guardian",
  "description": "Track and safely manage OpenClaw version lifecycle on Pi. Use when checking",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:jarvis-mini-openclaw-release-guardian:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "jarvis_openclaw_release_requested",
      "type": "pulse.event",
      "pattern": "jarvis:openclaw_release_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:jarvis-mini-openclaw-release-guardian"
    }
  ]
}
