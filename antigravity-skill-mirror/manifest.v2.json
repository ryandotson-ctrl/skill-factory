{
  "schema_version": "2.0.0",
  "display_name": "antigravity-skill-mirror",
  "description": "Audit and sync Antigravity global skills (~/.gemini/antigravity/skills)",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:antigravity-skill-mirror:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "skills_antigravity_mirror_requested",
      "type": "pulse.event",
      "pattern": "skills:antigravity_mirror_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:antigravity-skill-mirror"
    }
  ]
}
