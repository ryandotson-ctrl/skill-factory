{
    "schema_version": "2.0.0",
    "display_name": "Omniscient Skill Cataloger",
    "description": "Builds complete, source-aware skill inventories and classifies mirror drift across roots.",
    "dispatch": {
        "mode": "automatic",
        "cooldown": 300
    },
    "inputs": [
        {
            "id": "system_stability_trigger",
            "type": "pulse.event",
            "pattern": "stability_gate_check"
        }
    ],
    "outputs": [
        {
            "id": "status_update",
            "type": "pulse.event",
            "event_type": "omniscient_skill_cataloger_activity"
        }
    ]
}
