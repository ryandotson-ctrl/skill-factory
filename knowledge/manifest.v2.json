{
  "schema_version": "2.0.0",
  "display_name": "knowledge",
  "description": "Lean core knowledge skill for wisdom ledgers, knowledge graphs, context scheduling, and reusable recall.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:knowledge:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "recall_requested",
      "type": "pulse.event",
      "pattern": "knowledge:recall_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:knowledge",
      "event_producer_role": "core_status"
    },
    {
      "id": "recall_ready",
      "type": "pulse.event",
      "event_type": "knowledge:recall_ready",
      "event_producer_role": "knowledge_recall"
    }
  ],
  "awareness": [
    "watcher",
    "research",
    "skill-governor"
  ]
}
