{
  "schema_version": "2.0.0",
  "display_name": "Issue Tracker Guardian",
  "description": "Evidence-gated issue lifecycle manager with explicit route ownership for runtime and repo signals.",
  "dispatch": {
    "mode": "hybrid",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "issue_scan_requested",
      "type": "pulse.event",
      "pattern": "issue:scan_requested",
      "route_mode": "owned",
      "route_priority": 90
    },
    {
      "id": "issue_ingest_requested",
      "type": "pulse.event",
      "pattern": "issue:ingest_requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "issue_reconcile_requested",
      "type": "pulse.event",
      "pattern": "issue:reconcile_requested",
      "route_mode": "owned",
      "route_priority": 92
    },
    {
      "id": "qa_test_failed",
      "type": "pulse.event",
      "pattern": "qa:test_failed",
      "route_mode": "owned",
      "route_priority": 70
    },
    {
      "id": "git_push_complete",
      "type": "pulse.event",
      "pattern": "git:push_complete",
      "route_mode": "owned",
      "route_priority": 40
    },
    {
      "id": "log_anomaly_detected",
      "type": "pulse.event",
      "pattern": "log:anomaly_detected",
      "route_mode": "owned",
      "route_priority": 75
    }
  ],
  "outputs": [
    {
      "id": "issue_opened",
      "type": "pulse.event",
      "event_type": "issue:opened"
    },
    {
      "id": "issue_updated",
      "type": "pulse.event",
      "event_type": "issue:updated"
    },
    {
      "id": "issue_duplicate_detected",
      "type": "pulse.event",
      "event_type": "issue:duplicate_detected"
    },
    {
      "id": "issue_resolution_candidate",
      "type": "pulse.event",
      "event_type": "issue:resolution_candidate"
    },
    {
      "id": "issue_closed",
      "type": "pulse.event",
      "event_type": "issue:closed"
    },
    {
      "id": "issue_action_blocked",
      "type": "pulse.event",
      "event_type": "issue:action_blocked"
    }
  ],
  "automation_default": {
    "mode": "reconcile",
    "interval": "daily"
  }
}
