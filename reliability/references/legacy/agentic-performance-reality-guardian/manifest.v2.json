{
  "schema_version": "2.0.0",
  "display_name": "agentic-performance-reality-guardian",
  "description": "Portable performance and scale-risk guard for agentic changes. Use when a change can amplify work across users, requests, keystrokes, records, retries, streams, jobs, caches, or queues and needs load-shape analysis, guardrails, and observability before ship.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:agentic-performance-reality-guardian:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "performance_reality_check_requested",
      "type": "pulse.event",
      "pattern": "performance:reality_check_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:agentic-performance-reality-guardian"
    }
  ]
}
