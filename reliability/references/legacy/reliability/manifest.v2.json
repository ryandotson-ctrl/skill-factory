{
  "schema_version": "2.0.0",
  "display_name": "reliability",
  "description": "Stabilizes incidents, runtime failures, performance regressions, async hazards, logs, lifecycle issues, and resource budget failures.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:reliability:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "semantic_request",
      "type": "pulse.event",
      "pattern": "runtime:incident_detected",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:reliability",
      "event_producer_role": "core_status"
    },
    {
      "id": "ready",
      "type": "pulse.event",
      "event_type": "reliability:stabilization_ready",
      "event_producer_role": "core_ready"
    }
  ],
  "awareness": [
    "engineering",
    "security",
    "knowledge-data",
    "ml",
    "platforms",
    "automation"
  ]
}
