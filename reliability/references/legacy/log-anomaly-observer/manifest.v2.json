{
    "schema_version": "2.0.0",
    "display_name": "Log Anomaly Observer",
    "dispatch": {
        "mode": "automatic",
        "cooldown": 300
    },
    "inputs": [
        {
            "id": "log_error_burst",
            "type": "pulse.event",
            "pattern": "system.log_error"
        }
    ],
    "outputs": [
        {
            "id": "anomaly_signal",
            "type": "pulse.event",
            "event_type": "anomaly_detected"
        }
    ]
}