{
  "schema_version": "2.0.0",
  "display_name": "Capability Entitlement Negotiator",
  "dispatch": {
    "mode": "hybrid",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "launch_preflight_requested",
      "type": "pulse.event",
      "pattern": "launch:preflight_requested",
      "route_mode": "owned",
      "route_priority": 85
    },
    {
      "id": "capability_negotiation_requested",
      "type": "pulse.event",
      "pattern": "capability:negotiation_requested"
    }
  ],
  "outputs": [
    {
      "id": "entitlement_negotiated",
      "type": "pulse.event",
      "event_type": "capability:entitlement_negotiated"
    },
    {
      "id": "entitlement_blocked",
      "type": "pulse.event",
      "event_type": "capability:entitlement_blocked"
    }
  ]
}
