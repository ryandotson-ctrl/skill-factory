{
  "schema_version": "2.0.0",
  "display_name": "agentic-incident-triage-commander",
  "description": "Portable production incident triage commander for agentic systems. Use when something is down, degraded, flaky, timing out, corrupting data, or failing under pressure and Codex must reconstruct runtime mental models, request evidence, choose the safest mitigation, and drive recovery.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:agentic-incident-triage-commander:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "incident_triage_requested",
      "type": "pulse.event",
      "pattern": "incident:triage_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:agentic-incident-triage-commander"
    }
  ]
}
