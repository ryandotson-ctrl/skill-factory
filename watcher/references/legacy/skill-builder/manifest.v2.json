{
  "schema_version": "2.0.0",
  "display_name": "skill-builder",
  "description": "Lean core skill for creating, installing, packaging, and repairing skills or plugins.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:skill-builder:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "builder_requested",
      "type": "pulse.event",
      "pattern": "skills:builder_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:skill-builder",
      "event_producer_role": "core_status"
    },
    {
      "id": "builder_receipt_ready",
      "type": "pulse.event",
      "event_type": "skills:builder_receipt_ready",
      "event_producer_role": "builder_receipt"
    }
  ],
  "awareness": [
    "skill-governor",
    "watcher"
  ]
}
