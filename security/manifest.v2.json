{
  "schema_version": "2.0.0",
  "display_name": "security",
  "description": "Protects applications, data, identities, ownership boundaries, local systems, and networks from security and privacy failures.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:security:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "semantic_request",
      "type": "pulse.event",
      "pattern": "security:audit_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:security",
      "event_producer_role": "core_status"
    },
    {
      "id": "ready",
      "type": "pulse.event",
      "event_type": "security:review_ready",
      "event_producer_role": "core_ready"
    }
  ],
  "awareness": [
    "engineering",
    "reliability",
    "automation",
    "platforms",
    "knowledge-data"
  ]
}
