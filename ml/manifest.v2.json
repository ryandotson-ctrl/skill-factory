{
  "schema_version": "2.0.0",
  "display_name": "ml",
  "description": "Builds, tunes, evaluates, optimizes, quantizes, and stabilizes local and cloud model systems.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:ml:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "semantic_request",
      "type": "pulse.event",
      "pattern": "ml:work_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:ml",
      "event_producer_role": "core_status"
    },
    {
      "id": "ready",
      "type": "pulse.event",
      "event_type": "ml:work_ready",
      "event_producer_role": "core_ready"
    }
  ],
  "awareness": [
    "knowledge-data",
    "research",
    "reliability",
    "platforms",
    "engineering"
  ]
}
