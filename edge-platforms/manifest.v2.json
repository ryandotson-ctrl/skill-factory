{
  "schema_version": "2.0.0",
  "display_name": "edge-platforms",
  "description": "Lean core edge platform skill for Jarvis, OpenClaw, Pi, sensing, and constrained autonomy.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:edge-platforms:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "edge_platform_requested",
      "type": "pulse.event",
      "pattern": "edge:platform_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:edge-platforms",
      "event_producer_role": "core_status"
    },
    {
      "id": "operation_plan_ready",
      "type": "pulse.event",
      "event_type": "edge:operation_plan_ready",
      "event_producer_role": "edge_plan"
    }
  ],
  "awareness": [
    "reliability",
    "security",
    "research"
  ]
}
