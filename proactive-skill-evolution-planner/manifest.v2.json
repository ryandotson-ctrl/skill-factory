{
    "schema_version": "2.0.0",
    "display_name": "Proactive Skill Evolution Planner",
    "description": "Deterministic planner for intervention-first, signal-aware skill evolution and mirror-safe upgrade sequencing.",
    "dispatch": {
        "mode": "automatic",
        "cooldown": 600
    },
    "inputs": [
        {
            "id": "skill_director_activity",
            "type": "pulse.event",
            "pattern": "skill_director_activity"
        },
        {
            "id": "postmortem_generated",
            "type": "pulse.event",
            "pattern": "postmortem_generated"
        },
        {
            "id": "skill_evolution_requested",
            "type": "pulse.event",
            "pattern": "skill_evolution_requested"
        }
    ],
    "outputs": [
        {
            "id": "skill_evolution_plan",
            "type": "pulse.event",
            "event_type": "skill_evolution_plan_emitted"
        },
        {
            "id": "skill_recommendation",
            "type": "pulse.event",
            "event_type": "skill_recommendation_emitted"
        },
        {
            "id": "skill_evolution_scorecard",
            "type": "pulse.event",
            "event_type": "skill_evolution_scorecard_emitted"
        }
    ]
}
