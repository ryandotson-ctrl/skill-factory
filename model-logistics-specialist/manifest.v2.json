{
    "schema_version": "2.0.0",
    "display_name": "Model Logistics Specialist",
    "dispatch": {
        "mode": "automatic",
        "cooldown": 300
    },
    "inputs": [
        {
            "id": "system_stability_trigger",
            "type": "pulse.event",
            "pattern": "stability_gate_check"
        },
        {
            "id": "bundle_preflight_trigger",
            "type": "pulse.event",
            "pattern": "release_bundle_preflight_requested"
        }
    ],
    "outputs": [
        {
            "id": "status_update",
            "type": "pulse.event",
            "event_type": "model_logistics_specialist_activity"
        },
        {
            "id": "bundle_preflight_report",
            "type": "pulse.event",
            "event_type": "model_bundle_preflight_reported"
        }
    ]
}
