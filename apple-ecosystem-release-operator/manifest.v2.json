{
  "schema_version": "2.0.0",
  "display_name": "Apple Ecosystem Release Operator",
  "description": "Profile-driven Apple release workflow for archive, upload, internal TestFlight follow-through, and evidence capture.",
  "dispatch": {
    "mode": "manual",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "apple_release_requested",
      "type": "pulse.event",
      "pattern": "apple:release_requested"
    }
  ],
  "outputs": [
    {
      "id": "apple_release_receipt",
      "type": "pulse.event",
      "event_type": "apple_release_operator_receipt"
    }
  ]
}
