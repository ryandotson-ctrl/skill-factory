{
    "schema_version": "2.0.0",
    "display_name": "Async Hygiene Monitor",
    "dispatch": {
        "mode": "automatic",
        "cooldown": 600
    },
    "inputs": [
        {
            "id": "root_cause_trigger",
            "type": "pulse.event",
            "pattern": "root_cause_identified"
        }
    ],
    "outputs": [
        {
            "id": "fix_signal",
            "type": "pulse.event",
            "event_type": "async_fix_proposed"
        }
    ]
}