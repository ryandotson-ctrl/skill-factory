{
    "schema_version": "2.0.0",
    "display_name": "Log Detective SRE",
    "dispatch": {
        "mode": "automatic",
        "cooldown": 60
    },
    "inputs": [
        {
            "id": "anomaly_trigger",
            "type": "pulse.event",
            "pattern": "anomaly_detected"
        },
        {
            "id": "ipc_error_trigger",
            "type": "pulse.event",
            "pattern": "backend_ipc_error_detected"
        }
    ],
    "outputs": [
        {
            "id": "root_cause_signal",
            "type": "pulse.event",
            "event_type": "root_cause_identified"
        },
        {
            "id": "transport_rca_signal",
            "type": "pulse.event",
            "event_type": "backend_transport_rca_reported"
        }
    ]
}
