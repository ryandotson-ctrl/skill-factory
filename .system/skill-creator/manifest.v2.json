{
  "schema_version": "2.0.0",
  "display_name": "Skill Creator",
  "description": "Guide for creating or updating Codex skills with strong packaging, metadata, and workflow design.",
  "dispatch": {
    "mode": "manual",
    "cooldown": 300
  },
  "inputs": [
    {
      "id": "skill_request",
      "type": "pulse.event",
      "pattern": "skill:skill-creator:requested",
      "route_mode": "owned",
      "route_priority": 95
    },
    {
      "id": "skills_creation_requested",
      "type": "pulse.event",
      "pattern": "skills:creation_requested",
      "route_mode": "owned",
      "route_priority": 90
    }
  ],
  "outputs": [
    {
      "id": "creation_guidance_ready",
      "type": "pulse.event",
      "event_type": "skills:creation_guidance_ready",
      "event_producer_role": "creator_guidance"
    },
    {
      "id": "status_update",
      "type": "pulse.event",
      "event_type": "skill_activity:skill-creator",
      "event_producer_role": "creator_status"
    }
  ]
}
