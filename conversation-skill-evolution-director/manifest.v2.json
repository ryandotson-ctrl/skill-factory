{
  "schema_version": "2.0.0",
  "display_name": "Conversation Skill Evolution Director",
  "description": "Core session-to-action engine for The Watcher and a standalone strategist for additive, portability-safe skill evolution decisions.",
  "dispatch": {
    "mode": "automatic",
    "cooldown": 240
  },
  "inputs": [
    {
      "id": "evolution_requested",
      "type": "pulse.event",
      "pattern": "skill_evolution_requested",
      "route_mode": "owned",
      "route_priority": 90
    },
    {
      "id": "watcher_activity",
      "type": "pulse.event",
      "pattern": "skill_director_activity",
      "route_mode": "broadcast",
      "route_priority": 70
    }
  ],
  "outputs": [
    {
      "id": "assessment_emitted",
      "type": "pulse.event",
      "event_type": "skill_evolution_assessment_emitted"
    },
    {
      "id": "actions_emitted",
      "type": "pulse.event",
      "event_type": "skill_evolution_actions_emitted"
    },
    {
      "id": "plan_emitted",
      "type": "pulse.event",
      "event_type": "skill_evolution_plan_emitted"
    }
  ]
}
